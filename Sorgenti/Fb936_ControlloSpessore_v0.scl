FUNCTION_BLOCK "Fb936_ControlloSpessore_v0"
{ S7_Optimized_Access := 'FALSE' }
VERSION : 1.0
// =============================================================================
//  Fb936_ControlloSpessore_v0  —  VERSION 1.0
//
//  MODIFICHE v1.0 rispetto alla v0.2
//    - Rilevamento doppio disco basato su aProfiloSpessore (compensato baseline)
//      e non più sul buffer temporale Dati[0..100]
//    - nLettureConsecutiveAllarme ora è un conteggio POSIZIONALE:
//        numero di celle del profilo con spessore > SpessoreMassimo
//      (suggerito: ridurre il valore da 15 campioni a ~5 celle tipicamente)
//    - Laser range validation: migrata su I_Spessore_mm (valore grezzo)
//      così i limiti sono espressi nel dominio fisico del sensore,
//      indipendenti dalla polarità logica configurata via I_InvertiLettura
//    - Nuove uscite O_nCelleFuoriSoglia e O_LaserInRange (diagnostica)
//    - Buffer Dati[0..100] mantenuto solo per diagnostica HMI
//
//  MODIFICHE v0.2
//    - Profilometro posizionale su array MaxData+1 celle
//    - Taratura automatica tramite AbilitaTaratura
//    - Compensazione baseline
//    - Output scalari sintesi passata
//
//  UDT "UdtControlloSpessore" richiede:
//    PosizioneCentroVentosa     : Real
//    RangeControllo             : Real
//    RangeRallenta              : Real
//    nLettureConsecutiveAllarme : Real  ← ora inteso come N celle posizionali
//    SpessoreMassimo            : Real
//    OvrTrasfertPerpassaggio    : LReal
//    DisabilitaControllo        : Bool
//    AbilitaTaratura            : Bool
//    SpessoreDiscoRiferimento   : Real
// =============================================================================
   VAR_INPUT 
      I_ParametriCntrolloSpessore : "UdtControlloSpessore";
      I_Spessore_mm : Real;
      I_InvertiLettura : Bool;   // moltiplica per -1
      I_PiecePresence : Bool;
      I_ActPosition : LReal;
      I_ActSpeed : LReal;
      I_DirLavoro : Int;   // 0=entrambe  1=solo positive  2=solo negative
      I_MaxRangeLaser : Real;   // [mm] limite max fisico sensore (valore grezzo)
      I_MinRangeLaser : Real;   // [mm] limite min fisico sensore (valore grezzo)
   END_VAR

   VAR_OUTPUT 
      O_SpessoreOk : Bool;
      O_SpessoreNOK : Bool;
      O_AlmControlloDisattivo : Bool;
      O_TaraturaAttiva : Bool;
      O_TaraturaCompletata : Bool;
      O_SpessoreMedio : Real;   // [mm] media passata (compensato baseline)
      O_SpessoreMax : Real;   // [mm] massimo passata (compensato baseline)
      O_DeltaMedio : Real;   // [mm] delta medio vs SpessoreDiscoRiferimento
      O_DeltaMax : Real;   // [mm] delta max vs SpessoreDiscoRiferimento
      O_nCelleProfilo : Int;   // [n]  celle profilo campionate
      O_nCelleFuoriSoglia : Int;   // [n]  celle con aProfiloSpessore > SpessoreMassimo
      O_LaserInRange : Bool;   // stato validità laser corrente (diagnostica)
   END_VAR

   VAR_IN_OUT 
      IO_OvrAuto : LReal;
      IO_OvrMan : LReal;
   END_VAR

   VAR 
      Pinza : Struct
         InZonaControllo : Bool;
         InZonaRallenta : Bool;
         OvrAutoOld { S7_SetPoint := 'True'} : LReal;
         OvrManOld { S7_SetPoint := 'True'} : LReal;
         nLettureConsecutive : Real;   // mantenuto per retrocompatibilità HMI
      END_STRUCT;
      aBaseline : Array[0..#MaxData] of Real;   // offset geometrico per posizione
      baselineValida : Bool;
      Fp {InstructionName := 'R_TRIG'; LibVersion := '1.0'; S7_SetPoint := 'False'} : R_TRIG;
      Fn {InstructionName := 'F_TRIG'; LibVersion := '1.0'; S7_SetPoint := 'False'} : F_TRIG;
      FpSlowing {InstructionName := 'R_TRIG'; LibVersion := '1.0'; S7_SetPoint := 'False'} : R_TRIG;
      FnSlowing {InstructionName := 'F_TRIG'; LibVersion := '1.0'; S7_SetPoint := 'False'} : F_TRIG;
      FpTaratura {InstructionName := 'R_TRIG'; LibVersion := '1.0'; S7_SetPoint := 'False'} : R_TRIG;
      DirOk : Bool;
      Ripeti : Bool;   // solo per test
      index : Int;
      AppMinIndexSurce : Int;   // deprecato, mantenuto per compat DB
      AppMaxIndexSurce : Int;   // deprecato
      AppMaxIndex : Int;   // deprecato Buffer temporale (solo diagnostica HMI; NON usato per OK/NOK in v1.0)
      Dati : Array[0..100] of Struct
         Spessore : Real;
         Pos : Real;
         Speed : Real;
      END_STRUCT;
      taraturaInCorso : Bool;   // Buffer profilometro posizionale
      aSomRaw : Array[0..#MaxData] of Real;
      aNraw : Array[0..#MaxData] of Int;
      aSomCal : Array[0..#MaxData] of Real;
      aNcal : Array[0..#MaxData] of Int;
      aProfiloSpessore : Array[0..#MaxData] of Real;   // compensato baseline
      aProfiloDelta : Array[0..#MaxData] of Real;   // vs SpessoreDiscoRiferimento Risultati scalari ultima passata
      AppSpessoreOk : Bool;
      AppSpessoreNok : Bool;
      AppSpessoreMedio : Real;
      AppSpessoreMax : Real;
      AppDeltaMedio : Real;
      AppDeltaMax : Real;
      AppNcelleProfilo : Int;
      AppNcelleFuoriSoglia : Int;
      AppValidValue : Bool;
   END_VAR

   VAR_TEMP 
      Max : Real;
      Min : Real;
      Spessore_mm : Real;
      i : Int;
      K : Int;
      m : Int;
      nLettureConsecutiveAllarme : Int;
      idx : Int;
      posInizio : Real;
      risoluzione : Real;
      tempR : Real;
      tempIdx : Int;
      nLettureTot : Int;
      nCelleFuori : Int;
      valSpessore : Real;
   END_VAR

   VAR CONSTANT 
      "Rv0+" : Real := 1.0;
      "Rv0-" : Real := -1.0;
      MaxData : Int := 600;
   END_VAR


BEGIN
	
	
	REGION InRange di controllo
	    
	    CASE #I_DirLavoro OF
	        0://0=entrambe
	            #DirOk := (#I_ActSpeed < #"Rv0-") OR (#I_ActSpeed > #"Rv0+");
	        1:  //1=solo positive
	            #DirOk := (#I_ActSpeed > #"Rv0+");
	        2:  //2=solo negative
	            #DirOk := (#I_ActSpeed < #"Rv0-");
	        ELSE
	            #DirOk := false;
	    END_CASE;
	    
	    #Max := #I_ParametriCntrolloSpessore.PosizioneCentroVentosa + #I_ParametriCntrolloSpessore.RangeControllo;
	    #Min := #I_ParametriCntrolloSpessore.PosizioneCentroVentosa - #I_ParametriCntrolloSpessore.RangeControllo;
	    #Pinza.InZonaControllo := (#I_ActPosition >= #Min) AND (#I_ActPosition <= #Max) AND #DirOk AND #I_PiecePresence;
	    
	    #Max := #I_ParametriCntrolloSpessore.PosizioneCentroVentosa + #I_ParametriCntrolloSpessore.RangeControllo + #I_ParametriCntrolloSpessore.RangeRallenta;
	    #Min := #I_ParametriCntrolloSpessore.PosizioneCentroVentosa - #I_ParametriCntrolloSpessore.RangeControllo - #I_ParametriCntrolloSpessore.RangeRallenta;
	    #Pinza.InZonaRallenta := (#I_ActPosition >= #Min) AND (#I_ActPosition <= #Max) AND #DirOk AND #I_PiecePresence;
	    
	    // Mappatura posizione → indice array [0..MaxData]
	    #posInizio := #I_ParametriCntrolloSpessore.PosizioneCentroVentosa
	    - #I_ParametriCntrolloSpessore.RangeControllo;
	    IF #I_ParametriCntrolloSpessore.RangeControllo > 0.0 THEN
	        #risoluzione := (2.0 * #I_ParametriCntrolloSpessore.RangeControllo) / INT_TO_REAL(#MaxData);
	    ELSE
	        #risoluzione := 1.0;   // fallback: evita divisione per zero
	    END_IF;
	    
	END_REGION
	
	REGION Laser validate range
	    // v1.0: la validazione è sul valore GREZZO del sensore.
	    //       I limiti rappresentano il range fisico del laser (es. 10..100 mm),
	    //       indipendenti dalla polarità logica configurata via I_InvertiLettura.
	    #AppValidValue := (#I_Spessore_mm >= #I_MinRangeLaser)
	    AND (#I_Spessore_mm <= #I_MaxRangeLaser);
	END_REGION
	
	REGION SPESSORE
	    IF #I_InvertiLettura THEN
	        #Spessore_mm := #I_Spessore_mm * -1.0;
	    ELSE
	        #Spessore_mm := #I_Spessore_mm;
	    END_IF;
	END_REGION
	
	REGION cambio ovr per controllo abilitato 
	    #FpSlowing(CLK := #Pinza.InZonaRallenta);
	    #FnSlowing(CLK := #Pinza.InZonaRallenta);
	    
	    IF #FpSlowing.Q THEN
	        #Pinza.OvrAutoOld := #IO_OvrAuto;
	        #Pinza.OvrManOld := #IO_OvrMan;
	        IF #IO_OvrAuto > #I_ParametriCntrolloSpessore.OvrTrasfertPerpassaggio THEN
	            #IO_OvrAuto := #I_ParametriCntrolloSpessore.OvrTrasfertPerpassaggio;
	        END_IF;
	        IF #IO_OvrMan > #I_ParametriCntrolloSpessore.OvrTrasfertPerpassaggio THEN
	            #IO_OvrMan := #I_ParametriCntrolloSpessore.OvrTrasfertPerpassaggio;
	        END_IF;
	        #index := 0;
	    END_IF;
	    
	    IF #FnSlowing.Q THEN
	        #IO_OvrAuto := #Pinza.OvrAutoOld;
	        #IO_OvrMan := #Pinza.OvrManOld;
	    END_IF;
	    
	END_REGION
	
	REGION avvio taratura
	    // Sul fronte di salita di AbilitaTaratura (solo se pinza NON è in zona):
	    //   1. pulisce i buffer di calibrazione
	    //   2. invalida la baseline esistente
	    //   3. arma il flag taraturaInCorso → prossima passata = taratura
	    
	    #FpTaratura(CLK := #I_ParametriCntrolloSpessore.AbilitaTaratura);
	    
	    IF #FpTaratura.Q AND NOT #Pinza.InZonaControllo THEN
	        #taraturaInCorso := TRUE;
	        #baselineValida := FALSE;
	        FOR #i := 0 TO #MaxData DO
	            #aSomCal[#i] := 0.0;
	            #aNcal[#i] := 0;
	        END_FOR;
	    END_IF;
	END_REGION
	
	REGION controllo spessore
	    #Fp(CLK := #Pinza.InZonaControllo);
	    #Fn(CLK := #Pinza.InZonaControllo);
	    
	    // ═══ RESET ad ogni inizio passata ═══
	    IF #Fp.Q THEN
	        #Pinza.nLettureConsecutive := 0.0;
	        #AppSpessoreOk := false;
	        #AppSpessoreNok := false;
	        #AppMaxIndex := 0;
	        #AppMinIndexSurce := 0;
	        #AppMaxIndexSurce := 0;
	        #index := 0;
	        // Reset buffer temporale (diagnostica)
	        FOR #i := 0 TO 100 DO
	            #Dati[#i].Pos := 0.0;
	            #Dati[#i].Speed := 0.0;
	            #Dati[#i].Spessore := 0.0;
	        END_FOR;
	        // Reset buffer profilo posizionale (solo se NON in taratura)
	        IF NOT #taraturaInCorso THEN
	            FOR #i := 0 TO #MaxData DO
	                #aSomRaw[#i] := 0.0;
	                #aNraw[#i] := 0;
	            END_FOR;
	        END_IF;
	    END_IF;
	    
	    // ═══ ACQUISIZIONE ad ogni ciclo in zona (con gate su AppValidValue) ═══
	    IF #Pinza.InZonaControllo AND #AppValidValue AND NOT #Fp.Q AND NOT #Fn.Q THEN
	        
	        // Buffer temporale (diagnostica)
	        IF #index <= 100 THEN
	            #Dati[#index].Spessore := #Spessore_mm;
	            #Dati[#index].Speed := LREAL_TO_REAL(#I_ActSpeed);
	            #Dati[#index].Pos := LREAL_TO_REAL(#I_ActPosition);
	        END_IF;
	        #index := #index + 1;
	        
	        // Buffer profilo posizionale
	        #idx := REAL_TO_INT((LREAL_TO_REAL(#I_ActPosition) - #posInizio) / #risoluzione);
	        IF #idx < 0 THEN
	            #idx := 0;
	        END_IF;
	        IF #idx > #MaxData THEN
	            #idx := #MaxData;
	        END_IF;
	        
	        IF #taraturaInCorso THEN
	            #aSomCal[#idx] := #aSomCal[#idx] + #Spessore_mm;
	            #aNcal[#idx] := #aNcal[#idx] + 1;
	        ELSE
	            #aSomRaw[#idx] := #aSomRaw[#idx] + #Spessore_mm;
	            #aNraw[#idx] := #aNraw[#idx] + 1;
	        END_IF;
	    END_IF;
	    
	    // ═══ FINE PASSATA: elaborazione e rilevamento ═══
	    #nLettureConsecutiveAllarme := REAL_TO_INT(#I_ParametriCntrolloSpessore.nLettureConsecutiveAllarme);
	    
	    IF (#Fn.Q OR #Ripeti) THEN
	        
	        IF #taraturaInCorso THEN
	            // ─── RAMO TARATURA: calcolo baseline ───
	            FOR #i := 0 TO #MaxData DO
	                IF #aNcal[#i] > 0 THEN
	                    #aBaseline[#i] := (#aSomCal[#i] / INT_TO_REAL(#aNcal[#i]))
	                    - #I_ParametriCntrolloSpessore.SpessoreDiscoRiferimento;
	                ELSE
	                    #aBaseline[#i] := 0.0;
	                END_IF;
	                #aSomCal[#i] := 0.0;
	                #aNcal[#i] := 0;
	            END_FOR;
	            #baselineValida := TRUE;
	            #taraturaInCorso := FALSE;
	            // La taratura non concorre al giudizio OK/NOK misura
	            #AppSpessoreOk := TRUE;
	            #AppSpessoreNok := FALSE;
	            #AppNcelleFuoriSoglia := 0;
	            
	        ELSE
	            // ─── RAMO MISURA NORMALE ───
	            
	            // STEP 1: costruzione profilo e scalari di sintesi
	            //   aProfiloSpessore[i] = media(aSomRaw[i]) - aBaseline[i]
	            //   aProfiloDelta[i]    = aProfiloSpessore[i] - SpessoreDiscoRiferimento
	            //   Celle non campionate: mantengono il valore della passata precedente
	            //   (garantisce profilo continuo su HMI; il rilevamento OK/NOK
	            //    scarta queste celle grazie al check su aNraw[i] > 0)
	            #AppSpessoreMedio := 0.0;
	            #AppSpessoreMax := 0.0;
	            #AppDeltaMedio := 0.0;
	            #AppDeltaMax := 0.0;
	            #nLettureTot := 0;
	            
	            FOR #i := 0 TO #MaxData DO
	                IF #aNraw[#i] > 0 THEN
	                    #tempR := #aSomRaw[#i] / INT_TO_REAL(#aNraw[#i]);
	                    #aProfiloSpessore[#i] := #tempR - #aBaseline[#i];
	                    #aProfiloDelta[#i] := #aProfiloSpessore[#i]
	                    - #I_ParametriCntrolloSpessore.SpessoreDiscoRiferimento;
	                    
	                    #AppSpessoreMedio := #AppSpessoreMedio + #aProfiloSpessore[#i];
	                    #AppDeltaMedio := #AppDeltaMedio + #aProfiloDelta[#i];
	                    IF #aProfiloSpessore[#i] > #AppSpessoreMax THEN
	                        #AppSpessoreMax := #aProfiloSpessore[#i];
	                    END_IF;
	                    IF #aProfiloDelta[#i] > #AppDeltaMax THEN
	                        #AppDeltaMax := #aProfiloDelta[#i];
	                    END_IF;
	                    #nLettureTot := #nLettureTot + 1;
	                END_IF;
	            END_FOR;
	            
	            IF #nLettureTot > 0 THEN
	                #AppSpessoreMedio := #AppSpessoreMedio / INT_TO_REAL(#nLettureTot);
	                #AppDeltaMedio := #AppDeltaMedio / INT_TO_REAL(#nLettureTot);
	            END_IF;
	            #AppNcelleProfilo := #nLettureTot;
	            
	            // STEP 2: NUOVO v1.0 – rilevamento basato su baseline
	            //   Conta celle campionate con aProfiloSpessore > SpessoreMassimo
	            //   Se count >= nLettureConsecutiveAllarme → NOK
	            //
	            //   Vantaggi vs vecchio algoritmo su Dati[0..100]:
	            //     + usa valore GIÀ compensato baseline (no offset macchina)
	            //     + usa valore GIÀ mediato per cella (rumore ridotto)
	            //     + non dipende dalla consecutività temporale dei campioni
	            //     + robusto a gap di campionamento (celle vuote ignorate)
	            //     + 601 celle vs 101 → miglior risoluzione posizionale
	            //
	            //   Se baseline NON tarata: aBaseline[i]=0, quindi
	            //     aProfiloSpessore[i] = media letture grezze → comportamento
	            //     degradato ma funzionale (senza compensazione offset).
	            #nCelleFuori := 0;
	            FOR #i := 0 TO #MaxData DO
	                IF #aNraw[#i] > 0 THEN
	                    IF #aProfiloSpessore[#i] > #I_ParametriCntrolloSpessore.SpessoreMassimo THEN
	                        #nCelleFuori := #nCelleFuori + 1;
	                    END_IF;
	                END_IF;
	            END_FOR;
	            
	            #AppNcelleFuoriSoglia := #nCelleFuori;
	            #Pinza.nLettureConsecutive := INT_TO_REAL(#nCelleFuori);
	            
	            IF #nCelleFuori >= #nLettureConsecutiveAllarme THEN
	                #AppSpessoreNok := TRUE;
	                #AppSpessoreOk := FALSE;
	            ELSE
	                #AppSpessoreNok := FALSE;
	                #AppSpessoreOk := TRUE;
	            END_IF;
	            
	        END_IF;   // fine IF taraturaInCorso
	        
	        #Ripeti := false;
	    END_IF;
	END_REGION
	
	REGION uscite
	    #O_SpessoreNOK := NOT #I_ParametriCntrolloSpessore.DisabilitaControllo AND #AppSpessoreNok;
	    #O_SpessoreOk := #I_ParametriCntrolloSpessore.DisabilitaControllo OR #AppSpessoreOk;
	    #O_AlmControlloDisattivo := #I_ParametriCntrolloSpessore.DisabilitaControllo;
	    #O_TaraturaAttiva := #taraturaInCorso;
	    #O_TaraturaCompletata := #baselineValida;
	    #O_SpessoreMedio := #AppSpessoreMedio;
	    #O_SpessoreMax := #AppSpessoreMax;
	    #O_DeltaMedio := #AppDeltaMedio;
	    #O_DeltaMax := #AppDeltaMax;
	    #O_nCelleProfilo := #AppNcelleProfilo;
	    #O_nCelleFuoriSoglia := #AppNcelleFuoriSoglia;
	    #O_LaserInRange := #AppValidValue;
	END_REGION
	
	ENO := true;
	
	
END_FUNCTION_BLOCK

